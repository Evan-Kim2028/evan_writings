<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Evan's Writings</title>
  <meta name="description" content="{{ description or 'Collected writings on DeFi, data, MEV, and math by Evan Kim.' }}">
  <meta name="author" content="Evan Kim">
  <meta name="theme-color" content="#0a0a0f">
  <meta property="og:site_name" content="Evan's Writings">
  <meta property="og:title" content="{% if title %}{{ title }}{% else %}Evan's Writings{% endif %}">
  <meta property="og:description" content="{{ description or 'Collected writings on DeFi, data, MEV, and math by Evan Kim.' }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ page.url | absoluteUrl }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if title %}{{ title }}{% else %}Evan's Writings{% endif %}">
  <meta name="twitter:description" content="{{ description or 'Collected writings on DeFi, data, MEV, and math by Evan Kim.' }}">
  <link rel="icon" href="{{ '/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="stylesheet" href="{{ '/styles.css' | url }}?v=5">
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <header>
    <nav aria-label="Main">
      <a href="{{ '/' | url }}" class="brand" aria-label="Evan's Writings home">Evan's Writings</a>
      <div class="nav-links">
        <a href="{{ '/writings/' | url }}">All Writings</a>
        <a href="{{ '/collections/' | url }}">Collections</a>
        <a href="{{ '/llms-full.txt' | url }}">llms-full.txt</a>
      </div>
    </nav>
  </header>
  <main id="main">
    {{ content | safe }}
  </main>
  <footer>
    <p>Collected works of Evan Kim. <a href="https://github.com/Evan-Kim2028/evan_writings">Source</a>.</p>
  </footer>
</body>
</html>
