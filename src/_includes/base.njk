<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Evan's Writings</title>
  <meta name="description" content="{{ description or 'Collected writings on DeFi, data, MEV, and math by Evan Kim.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/styles.css' | url }}">
</head>
<body>
  <header>
    <nav>
      <a href="{{ '/' | url }}" class="brand">Evan's Writings</a>
      <div class="nav-links">
        <a href="{{ '/writings/' | url }}">All Writings</a>
        <a href="{{ '/collections/' | url }}">Collections</a>
        <a href="{{ '/llms-full.txt' | url }}">llms-full.txt</a>
      </div>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>Collected works of Evan Kim. <a href="https://github.com/Evan-Kim2028/evan_writings">Source</a>.</p>
  </footer>
</body>
</html>
