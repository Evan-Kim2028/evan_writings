---
title: Collections
layout: base.njk
---

<section class="page-header">
  <h1>Collections</h1>
  <p class="page-description">Browse writings by topic.</p>
</section>

{% set groups = collections.writings | sortByDate | groupByCollection %}
{% for collection, items in groups %}
<section class="collection-group">
  <div class="collection-group-header">
    <h2 id="{{ collection }}">{{ collection | title }}</h2>
    <a href="{{ '/collections/' | url }}{{ collection }}/" class="view-all">View all {{ items.length }} →</a>
  </div>
  <ul class="writing-list writing-list-cards">
  {% for writing in items %}
    <li class="writing-list-item">
      <a href="{{ writing.url | url }}" class="writing-list-title">{{ writing.data.title }}</a>
      <span class="writing-list-meta">{{ writing.data.date | formatDate }}</span>
    </li>
  {% endfor %}
  </ul>
</section>
{% endfor %}
